<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniLinker.UI.Controls.SignalStrengthControl">

  <UserControl.Resources>
    <!-- 信号条样式 -->
    <SolidColorBrush x:Key="SignalActiveExcellent" Color="#22C55E"/>
    <SolidColorBrush x:Key="SignalActiveGood" Color="#84CC16"/>
    <SolidColorBrush x:Key="SignalActiveFair" Color="#F59E0B"/>
    <SolidColorBrush x:Key="SignalActivePoor" Color="#EF4444"/>
    <SolidColorBrush x:Key="SignalInactive" Color="#374151"/>
  </UserControl.Resources>

  <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
    <!-- 4格信号条，高度递增 -->
    <Border x:Name="Bar1" Width="3" Height="6" CornerRadius="1" Background="{StaticResource SignalInactive}"/>
    <Border x:Name="Bar2" Width="3" Height="9" CornerRadius="1" Background="{StaticResource SignalInactive}"/>
    <Border x:Name="Bar3" Width="3" Height="12" CornerRadius="1" Background="{StaticResource SignalInactive}"/>
    <Border x:Name="Bar4" Width="3" Height="15" CornerRadius="1" Background="{StaticResource SignalInactive}"/>
  </StackPanel>

</UserControl>
