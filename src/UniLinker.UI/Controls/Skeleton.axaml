<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniLinker.UI.Controls.Skeleton">

  <!-- 默认骨架元素 - 简化版本，使用纯色背景 -->
  <Border x:Name="SkeletonBorder"
          CornerRadius="8"
          Background="#1AFFFFFF"/>

</UserControl>
