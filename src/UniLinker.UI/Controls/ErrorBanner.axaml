<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniLinker.UI.Controls.ErrorBanner">

  <UserControl.Resources>
    <!-- 严重程度对应的背景色 -->
    <SolidColorBrush x:Key="InfoBackground" Color="#1A3B82F6"/>
    <SolidColorBrush x:Key="WarningBackground" Color="#1AF59E0B"/>
    <SolidColorBrush x:Key="ErrorBackground" Color="#1AEF4444"/>
    <SolidColorBrush x:Key="CriticalBackground" Color="#1AEF4444"/>

    <!-- 严重程度对应的边框色 -->
    <SolidColorBrush x:Key="InfoBorder" Color="#3B82F6"/>
    <SolidColorBrush x:Key="WarningBorder" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBorder" Color="#EF4444"/>
    <SolidColorBrush x:Key="CriticalBorder" Color="#EF4444"/>

    <!-- 严重程度对应的图标色 -->
    <SolidColorBrush x:Key="InfoIcon" Color="#3B82F6"/>
    <SolidColorBrush x:Key="WarningIcon" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorIcon" Color="#EF4444"/>
    <SolidColorBrush x:Key="CriticalIcon" Color="#EF4444"/>
  </UserControl.Resources>

  <!-- 主容器 -->
  <Border x:Name="MainBorder"
          CornerRadius="8"
          BorderThickness="1"
          Padding="16,12">
    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

      <!-- 图标 -->
      <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
              Width="24" Height="24" CornerRadius="12"
              Background="{DynamicResource ErrorBackground}"
              VerticalAlignment="Top" Margin="0,0,12,0">
        <TextBlock x:Name="IconText" Text="⚠" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>

      <!-- 消息和建议 -->
      <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
        <TextBlock x:Name="MessageText"
                   FontSize="14" FontWeight="Medium" Foreground="#E5E5E5"/>

        <!-- 建议/解决方案列表 -->
        <ItemsControl x:Name="SuggestionsList" Margin="0,4,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="• " FontSize="12" Foreground="#A3A3A3">
                <Run Text="{Binding}"/>
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <!-- 关闭按钮 -->
      <Button x:Name="CloseButton"
              Grid.Column="2" Grid.Row="0"
              Width="24" Height="24"
              CornerRadius="4"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand">
        <TextBlock Text="✕" FontSize="12" Foreground="#737373"/>
      </Button>

    </Grid>
  </Border>

</UserControl>
