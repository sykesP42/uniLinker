<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniLinker.UI.Controls.ToastNotification">

  <UserControl.Resources>
    <!-- Toast 类型对应的颜色 -->
    <SolidColorBrush x:Key="ToastSuccessBg" Color="#1A22C55E"/>
    <SolidColorBrush x:Key="ToastSuccessBorder" Color="#22C55E"/>
    <SolidColorBrush x:Key="ToastInfoBg" Color="#1A3B82F6"/>
    <SolidColorBrush x:Key="ToastInfoBorder" Color="#3B82F6"/>
    <SolidColorBrush x:Key="ToastWarningBg" Color="#1AF59E0B"/>
    <SolidColorBrush x:Key="ToastWarningBorder" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ToastErrorBg" Color="#1AEF4444"/>
    <SolidColorBrush x:Key="ToastErrorBorder" Color="#EF4444"/>
  </UserControl.Resources>

  <!-- Toast 卡片 -->
  <Border x:Name="ToastCard"
          CornerRadius="8"
          BorderThickness="1"
          Padding="16,10"
          MinWidth="280"
          MaxWidth="400"
          Background="#1A1A1A"
          BorderBrush="#262626">
    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

      <!-- 图标 -->
      <TextBlock x:Name="IconText" Grid.Column="0"
                 FontSize="16" Margin="0,0,10,0"
                 VerticalAlignment="Center"/>

      <!-- 消息 -->
      <TextBlock x:Name="MessageText" Grid.Column="1"
                 FontSize="13" Foreground="#E5E5E5"
                 TextWrapping="Wrap"
                 VerticalAlignment="Center"/>

      <!-- 关闭按钮 -->
      <Button Grid.Column="2"
              Width="20" Height="20"
              CornerRadius="4"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
              Margin="8,0,0,0"
              Click="OnCloseClick">
        <TextBlock Text="✕" FontSize="10" Foreground="#737373"/>
      </Button>

    </Grid>
  </Border>

</UserControl>
