<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════════
       深色主题 - 颜色资源
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- 背景层次 -->
  <Color x:Key="SystemBaseLowColor">#0A0A0A</Color>
  <Color x:Key="SystemBaseMediumColor">#141414</Color>
  <Color x:Key="SystemBaseHighColor">#1A1A1A</Color>
  <Color x:Key="SystemBaseHigherColor">#222222</Color>

  <!-- 文字颜色 -->
  <Color x:Key="SystemTextPrimaryColor">#E5E5E5</Color>
  <Color x:Key="SystemTextSecondaryColor">#A3A3A3</Color>
  <Color x:Key="SystemTextTertiaryColor">#737373</Color>
  <Color x:Key="SystemTextDisabledColor">#525252</Color>

  <!-- 主色调 -->
  <Color x:Key="SystemAccentColor">#6366F1</Color>
  <Color x:Key="SystemAccentLightColor">#818CF8</Color>
  <Color x:Key="SystemAccentDarkColor">#4F46E5</Color>

  <!-- 功能色 -->
  <Color x:Key="SystemSuccessColor">#22C55E</Color>
  <Color x:Key="SystemWarningColor">#F59E0B</Color>
  <Color x:Key="SystemErrorColor">#EF4444</Color>
  <Color x:Key="SystemInfoColor">#3B82F6</Color>

  <!-- 边框颜色 -->
  <Color x:Key="SystemBorderColor">#262626</Color>
  <Color x:Key="SystemBorderLightColor">#404040</Color>

  <!-- 画刷定义 -->
  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource SystemBaseLowColor}"/>
  <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource SystemBaseMediumColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SystemBaseHighColor}"/>
  <SolidColorBrush x:Key="SurfaceHigherBrush" Color="{StaticResource SystemBaseHigherColor}"/>

  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource SystemTextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource SystemTextSecondaryColor}"/>
  <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource SystemTextTertiaryColor}"/>
  <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource SystemTextDisabledColor}"/>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource SystemAccentColor}"/>
  <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource SystemAccentLightColor}"/>
  <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource SystemAccentDarkColor}"/>

  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SystemSuccessColor}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource SystemWarningColor}"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource SystemErrorColor}"/>
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource SystemInfoColor}"/>

  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource SystemBorderColor}"/>
  <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource SystemBorderLightColor}"/>

  <!-- 半透明画刷 -->
  <SolidColorBrush x:Key="AccentMutedBrush" Color="#1A6366F1"/>
  <SolidColorBrush x:Key="SuccessMutedBrush" Color="#1A22C55E"/>
  <SolidColorBrush x:Key="InfoMutedBrush" Color="#1A3B82F6"/>

</ResourceDictionary>