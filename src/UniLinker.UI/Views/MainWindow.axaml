<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UniLinker.UI.ViewModels"
        xmlns:pages="clr-namespace:UniLinker.UI.Views.Pages"
        xmlns:controls="clr-namespace:UniLinker.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="UniLinker.UI.Views.MainWindow"
        Title="UniLinker"
        WindowStartupLocation="CenterScreen"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        SystemDecorations="None"
        Background="#0A0A0A">

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="48,*">
    <!-- 标题栏 -->
    <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <!-- Logo -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0" Spacing="14">
          <Border Width="32" Height="32" CornerRadius="8" Background="#6366F1">
            <TextBlock Text="U" FontSize="16" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="UniLinker" FontSize="15" FontWeight="SemiBold" Foreground="#E5E5E5"
                     VerticalAlignment="Center"/>
          <Border Background="#1A6366F1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
            <TextBlock Text="v3.0" FontSize="11" Foreground="#818CF8"/>
          </Border>
        </StackPanel>

        <!-- 拖动区域 -->
        <Border Grid.Column="1" Background="Transparent"
                PointerPressed="OnTitleBarPointerPressed"/>

        <!-- 窗口控制按钮 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
          <!-- 最小化 -->
          <Button Width="46" Height="48" Background="Transparent" BorderThickness="0"
                  Click="OnMinimize" Cursor="Hand">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="#1AFFFFFF"/>
              </Style>
            </Button.Styles>
            <Panel Width="12" Height="12">
              <Line StartPoint="0,6" EndPoint="12,6" Stroke="#A3A3A3" StrokeThickness="1.5"/>
            </Panel>
          </Button>

          <!-- 最大化 -->
          <Button Width="46" Height="48" Background="Transparent" BorderThickness="0"
                  Click="OnMaximize" Cursor="Hand">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="#1AFFFFFF"/>
              </Style>
            </Button.Styles>
            <Panel Width="12" Height="12">
              <Rectangle Width="10" Height="10" Stroke="#A3A3A3" StrokeThickness="1.5"
                         Canvas.Left="1" Canvas.Top="1"/>
            </Panel>
          </Button>

          <!-- 关闭 -->
          <Button Width="46" Height="48" Background="Transparent" BorderThickness="0"
                  Click="OnClose" Cursor="Hand" x:Name="CloseButton">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="#E81123"/>
              </Style>
              <Style Selector="Button:pointerover /template/ ContentControl#PART_ContentPresenter">
                <Setter Property="Foreground" Value="White"/>
              </Style>
            </Button.Styles>
            <Panel Width="12" Height="12">
              <Line StartPoint="2,2" EndPoint="10,10" Stroke="#A3A3A3" StrokeThickness="1.5"/>
              <Line StartPoint="10,2" EndPoint="2,10" Stroke="#A3A3A3" StrokeThickness="1.5"/>
            </Panel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 主内容区域 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 侧边栏 -->
      <Border Grid.Column="0" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,1,1,0">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <!-- 导航标签 -->
          <Border Grid.Row="0" Padding="20,20">
            <TextBlock Text="导航" FontSize="11" FontWeight="SemiBold" Foreground="#525252"/>
          </Border>

          <!-- 分隔线 -->
          <Border Grid.Row="1" Height="1" Margin="20,0" Background="#1A1A1A"/>

          <!-- 导航列表 -->
          <ListBox Grid.Row="2" Margin="12,16" Background="Transparent" BorderThickness="0"
                   SelectionMode="Single" SelectedIndex="{Binding CurrentNavIndex}"
                   SelectionChanged="OnNavSelectionChanged">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#737373"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover">
                <Setter Property="Background" Value="#1AFFFFFF"/>
                <Setter Property="Foreground" Value="#E5E5E5"/>
              </Style>
              <Style Selector="ListBoxItem:selected">
                <Setter Property="Background" Value="#6366F1"/>
                <Setter Property="Foreground" Value="White"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="4"/>
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <!-- 仪表盘 -->
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Width="32" Height="32" CornerRadius="8" Background="#1A6366F1">
                  <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="仪表盘" VerticalAlignment="Center"/>
              </StackPanel>
            </ListBoxItem>

            <!-- 设备发现 -->
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Width="32" Height="32" CornerRadius="8" Background="#1A22C55E">
                  <TextBlock Text="📡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="设备发现" VerticalAlignment="Center"/>
              </StackPanel>
            </ListBoxItem>

            <!-- 屏幕分享 -->
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Width="32" Height="32" CornerRadius="8" Background="#1A3B82F6">
                  <TextBlock Text="🖥️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="屏幕分享" VerticalAlignment="Center"/>
              </StackPanel>
            </ListBoxItem>

            <!-- 设置 -->
            <ListBoxItem>
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Width="32" Height="32" CornerRadius="8" Background="#1A525252">
                  <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="设置" VerticalAlignment="Center"/>
              </StackPanel>
            </ListBoxItem>
          </ListBox>

          <!-- 状态卡片 (增强版 - 包含信号指示器) -->
          <Border Grid.Row="3" Margin="16" Padding="16" CornerRadius="12"
                  Background="#1A1A1A" BorderBrush="#262626" BorderThickness="1">
            <StackPanel Spacing="12">
              <!-- 连接状态行 -->
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Ellipse Width="10" Height="10" Fill="#22C55E"/>
                <TextBlock Text="服务运行中" FontSize="13" FontWeight="Medium" Foreground="#E5E5E5"/>
              </StackPanel>

              <!-- 信号强度指示器 -->
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="信号质量: " FontSize="11" Foreground="#737373"
                           VerticalAlignment="Center"/>
                <controls:SignalStrengthControl Grid.Column="1"
                                                Quality="{Binding ConnectionQuality}"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"/>
              </Grid>

              <!-- 监听地址 -->
              <TextBlock Text="{Binding ConnectAddress}" FontSize="12" Foreground="#737373"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- 内容区域 -->
      <Border Grid.Column="1" Padding="28" Background="#0A0A0A">
        <TransitioningContentControl Content="{Binding CurrentPage}">
          <TransitioningContentControl.PageTransition>
            <PageSlide Duration="0:0:0.2" Orientation="Horizontal"/>
          </TransitioningContentControl.PageTransition>
          <TransitioningContentControl.DataTemplates>
            <DataTemplate DataType="vm:DashboardViewModel">
              <pages:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="vm:DevicesViewModel">
              <pages:DevicesView/>
            </DataTemplate>
            <DataTemplate DataType="vm:ShareViewModel">
              <pages:ShareView/>
            </DataTemplate>
            <DataTemplate DataType="vm:SettingsViewModel">
              <pages:SettingsView/>
            </DataTemplate>
          </TransitioningContentControl.DataTemplates>
        </TransitioningContentControl>
      </Border>
    </Grid>

    <!-- Toast 通知容器 -->
    <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False" x:Name="ToastContainer"/>
  </Grid>

</Window>