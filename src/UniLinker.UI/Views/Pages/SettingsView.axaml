<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UniLinker.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="UniLinker.UI.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Spacing="20">
      <!-- General Settings -->
      <Border Classes="card">
        <StackPanel Spacing="20">
          <TextBlock Text="常规设置" FontSize="16" FontWeight="SemiBold"/>

          <!-- Device Name -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="设备名称" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <TextBox Grid.Column="1" Text="{Binding DeviceName}"/>
          </Grid>

          <!-- HTTP Port -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="HTTP 端口" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <TextBox Grid.Column="1" Text="{Binding HttpPort}"/>
          </Grid>

          <!-- Auto Start -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="开机自启动" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStart}"/>
          </Grid>

          <!-- Minimize to Tray -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="最小化到托盘" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}"/>
          </Grid>

          <!-- Theme -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="主题" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ComboBox Grid.Column="1" SelectedIndex="{Binding ThemeIndex}">
              <ComboBoxItem Content="深色"/>
              <ComboBoxItem Content="浅色"/>
              <ComboBoxItem Content="跟随系统"/>
            </ComboBox>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Quality Settings -->
      <Border Classes="card">
        <StackPanel Spacing="20">
          <TextBlock Text="默认画质设置" FontSize="16" FontWeight="SemiBold"/>

          <!-- Resolution -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="默认分辨率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ComboBox Grid.Column="1" SelectedIndex="{Binding DefaultResolution}">
              <ComboBoxItem Content="1080p (1920×1080)"/>
              <ComboBoxItem Content="2K (2560×1440)"/>
              <ComboBoxItem Content="4K (3840×2160)"/>
            </ComboBox>
          </Grid>

          <!-- Frame Rate -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="默认帧率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ComboBox Grid.Column="1" SelectedIndex="{Binding DefaultFps}">
              <ComboBoxItem Content="30 fps"/>
              <ComboBoxItem Content="60 fps"/>
            </ComboBox>
          </Grid>

          <!-- Bitrate -->
          <Grid ColumnDefinitions="160,*">
            <TextBlock Grid.Column="0" Text="默认码率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <ComboBox Grid.Column="1" SelectedIndex="{Binding DefaultBitrate}">
              <ComboBoxItem Content="10 Mbps"/>
              <ComboBoxItem Content="15 Mbps"/>
              <ComboBoxItem Content="20 Mbps"/>
            </ComboBox>
          </Grid>
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Text="关于" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock Text="UniLinker v3.0" Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBlock Text="跨设备低延迟投屏解决方案" FontSize="13"
                     Foreground="{DynamicResource TextTertiaryBrush}" Opacity="0.7"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>