<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UniLinker.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="UniLinker.UI.Views.Pages.ShareView"
             x:DataType="vm:ShareViewModel">

  <ScrollViewer>
    <StackPanel Spacing="20">
      <!-- Control Panel -->
      <Border Classes="card">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock Text="屏幕分享" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding StatusText}" FontSize="13"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Classes="success" CornerRadius="8" Padding="16,10"
                    Command="{Binding StartShareCommand}"
                    IsVisible="{Binding !IsSharing}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="▶️" FontSize="14"/>
                <TextBlock Text="开始分享"/>
              </StackPanel>
            </Button>
            <Button Classes="danger" CornerRadius="8" Padding="16,10"
                    Command="{Binding StopShareCommand}"
                    IsVisible="{Binding IsSharing}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⏹️" FontSize="14"/>
                <TextBlock Text="停止分享"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Connection Info -->
      <Border Classes="card" IsVisible="{Binding IsSharing}">
        <StackPanel Spacing="16">
          <TextBlock Text="连接信息" FontSize="16" FontWeight="SemiBold"/>
          <Border Background="{DynamicResource InfoMutedBrush}" CornerRadius="8" Padding="12">
            <StackPanel Spacing="4">
              <TextBlock Text="分享地址" FontSize="12" Foreground="{DynamicResource InfoBrush}"/>
              <TextBlock Text="{Binding ShareAddress}" FontWeight="SemiBold" FontSize="16"/>
            </StackPanel>
          </Border>
          <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="观看人数" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
              <TextBlock Text="{Binding ViewerCount}" FontWeight="SemiBold" FontSize="18"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="分辨率" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
              <TextBlock FontWeight="SemiBold" FontSize="18">
                <Run Text="{Binding ResolutionWidth}"/>
                <Run Text=" × "/>
                <Run Text="{Binding ResolutionHeight}"/>
              </TextBlock>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Settings -->
      <Border Classes="card">
        <StackPanel Spacing="20">
          <TextBlock Text="分享设置" FontSize="16" FontWeight="SemiBold"/>

          <!-- Resolution -->
          <Grid ColumnDefinitions="140,*">
            <TextBlock Grid.Column="0" Text="分辨率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <RadioButton Content="1080p" IsChecked="True"/>
              <RadioButton Content="2K"/>
              <RadioButton Content="4K"/>
            </StackPanel>
          </Grid>

          <!-- Frame Rate -->
          <Grid ColumnDefinitions="140,*">
            <TextBlock Grid.Column="0" Text="帧率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <RadioButton Content="30 fps" IsChecked="True"/>
              <RadioButton Content="60 fps"/>
            </StackPanel>
          </Grid>

          <!-- Bitrate -->
          <Grid ColumnDefinitions="140,*">
            <TextBlock Grid.Column="0" Text="码率" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <RadioButton Content="10 Mbps"/>
              <RadioButton Content="15 Mbps" IsChecked="True"/>
              <RadioButton Content="20 Mbps"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>