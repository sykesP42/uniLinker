<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UniLinker.UI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="UniLinker.UI.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <ScrollViewer>
    <StackPanel Spacing="20" Margin="0,0,0,20">
      <!-- Welcome Banner -->
      <Border CornerRadius="12" Padding="28" Background="{DynamicResource AccentBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding WelcomeText}" FontSize="26" FontWeight="Bold" Foreground="White"/>
          <TextBlock Text="{Binding Subtitle}" FontSize="14" Foreground="#CCFFFFFF"/>
        </StackPanel>
      </Border>

      <!-- Stats Cards -->
      <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
        <!-- Active Connections -->
        <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
          <StackPanel Spacing="12">
            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource SuccessMutedBrush}">
              <TextBlock Text="🔗" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding ActiveConnections}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
              <TextBlock Text="活跃连接" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Discovered Devices -->
        <Border Grid.Column="1" Classes="card" Margin="8,0">
          <StackPanel Spacing="12">
            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource InfoMutedBrush}">
              <TextBlock Text="📡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding DiscoveredDevices}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource InfoBrush}"/>
              <TextBlock Text="已发现设备" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Server Status -->
        <Border Grid.Column="2" Classes="card" Margin="8,0,0,0">
          <StackPanel Spacing="12">
            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource AccentMutedBrush}">
              <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding ServerStatus}" FontSize="22" FontWeight="Bold"/>
              <TextBlock Text="服务状态" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Quick Actions -->
      <StackPanel Spacing="16">
        <TextBlock Text="快速操作" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <Grid ColumnDefinitions="*,*">
          <Button Grid.Column="0" Classes="primary" Height="56" CornerRadius="10"
                  Margin="0,0,8,0" HorizontalContentAlignment="Left"
                  Click="OnStartShareClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="🖥️" FontSize="22"/>
              <StackPanel>
                <TextBlock Text="开始投屏" FontWeight="SemiBold" FontSize="15"/>
                <TextBlock Text="分享您的屏幕" FontSize="12" Opacity="0.8"/>
              </StackPanel>
            </StackPanel>
          </Button>

          <Button Grid.Column="1" Height="56" CornerRadius="10"
                  Margin="8,0,0,0" HorizontalContentAlignment="Left"
                  Click="OnDiscoverClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="🔍" FontSize="22"/>
              <StackPanel>
                <TextBlock Text="发现设备" FontWeight="SemiBold" FontSize="15"/>
                <TextBlock Text="扫描局域网" FontSize="12" Opacity="0.7"/>
              </StackPanel>
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>

</UserControl>