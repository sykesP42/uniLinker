<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern Card Style -->
    <Style x:Key="ModernCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Settings Section Header Style -->
    <Style x:Key="SettingsSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}">
        <Setter Property="Margin" Value="0,24,0,12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Modern Expander Style -->
    <Style x:Key="ModernExpanderStyle" TargetType="Expander">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Page Header Style -->
    <Style x:Key="PageHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,24"/>
    </Style>

    <!-- Stat Card Style -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="MinWidth" Value="200"/>
    </Style>

    <!-- Device Card Style -->
    <Style x:Key="DeviceCardStyle" TargetType="Grid">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
        <Setter Property="Width" Value="220"/>
        <Setter Property="Height" Value="160"/>
    </Style>

    <!-- Setting Row Style -->
    <Style x:Key="SettingRowStyle" TargetType="Grid">
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,8,0,8"/>
    </Style>

    <!-- Description Text Style -->
    <Style x:Key="DescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
</ResourceDictionary>