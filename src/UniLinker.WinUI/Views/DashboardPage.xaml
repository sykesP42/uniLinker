<Page
    x:Class="UniLinker.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="32,32,32,48" Spacing="24">
            <!-- Header Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding Loc.Dashboard}" Style="{StaticResource PageHeaderStyle}"/>
                <TextBlock Text="Monitor your connections and system status"
                           Style="{StaticResource DescriptionTextStyle}"
                           FontSize="14"/>
            </StackPanel>

            <!-- Status Banner -->
            <InfoBar
                x:Name="SystemStatusInfoBar"
                Severity="Success"
                IsOpen="True"
                IsClosable="False"
                Title="{Binding Loc.SystemReady}"
                Margin="0,0,0,8">
                <InfoBar.Content>
                    <TextBlock x:Name="SystemStatusText"
                               Text="Device: UniLinker-PC | Connections: 0 active"
                               Margin="0,4,0,0"/>
                </InfoBar.Content>
            </InfoBar>

            <!-- Stats Cards Grid -->
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Discovered Devices Card -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE970;" FontSize="20"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{Binding Loc.Discovered}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13"/>
                        </StackPanel>
                        <TextBlock x:Name="DiscoveredCount"
                                   Text="0"
                                   Style="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding Loc.DevicesLower}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Active Connections Card -->
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71B;" FontSize="20"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            <TextBlock Text="{Binding Loc.Active}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13"/>
                        </StackPanel>
                        <TextBlock x:Name="ActiveCount"
                                   Text="0"
                                   Style="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding Loc.Connections}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Share Sessions Card -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72D;" FontSize="20"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{Binding Loc.Share}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13"/>
                        </StackPanel>
                        <TextBlock x:Name="ShareCount"
                                   Text="0"
                                   Style="{StaticResource TitleLargeTextBlockStyle}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding Loc.Session}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Devices Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="{Binding Loc.RecentDevices}"
                           Style="{StaticResource SettingsSectionHeaderStyle}"
                           Margin="0,8,0,0"/>

                <ListView x:Name="RecentDevicesList"
                          ItemsSource="{Binding Devices.Devices, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                                    Padding="16">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Device Icon -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="20">
                                        <FontIcon Glyph="&#xE970;" FontSize="18"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Device Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"/>
                                        <TextBlock Text="{Binding IpAddress}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Column="2"
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="4"
                                            Padding="12,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Online"
                                                   Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="Medium"/>
                                    </Border>

                                    <!-- Action Button -->
                                    <Button Grid.Column="3"
                                            Content="View"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>